{
  "name": "arxiv-hound",
  "version": "0.0.1",
  "description": "Tiny arXiv MCP server and CLI: search, fetch, cite",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "arxiv-hound": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke": "node dist/cli.js search 'attention is all you need' --max 1",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "cac": "^6.7.14",
    "fast-xml-parser": "^4.5.0",
    "pdfjs-dist": "^4.7.76",
    "turndown": "^7.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/turndown": "^5.0.5",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "keywords": [
    "arxiv",
    "mcp",
    "mcp-server",
    "research",
    "papers",
    "semantic-scholar",
    "bibtex"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kanafm/arxiv-hound.git"
  },
  "homepage": "https://github.com/kanafm/arxiv-hound#readme",
  "bugs": {
    "url": "https://github.com/kanafm/arxiv-hound/issues"
  },
  "author": "kanafm",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
